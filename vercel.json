{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/price-history",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/refresh-prices",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/update-catalog",
      "schedule": "0 3 1 * *"
    }
  ]
}
