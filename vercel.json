{
  "buildCommand": "prisma generate --schema=prisma/schema-hostinger.prisma && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/consolidated",
      "schedule": "0 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "functions": {
    "app/api/download-catalog/[type]/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/download-catalogs/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/test-browser-download/route.ts": {
      "maxDuration": 60
    }
  }
}
