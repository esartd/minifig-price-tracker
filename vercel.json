{
  "buildCommand": "prisma generate --schema=prisma/schema-hostinger.prisma && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/backup-database",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/price-history",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/check-catalog-changes",
      "schedule": "0 2 1,15 * *"
    },
    {
      "path": "/api/cron/download-catalogs",
      "schedule": "30 2 1,15 * *"
    },
    {
      "path": "/api/cron/update-catalog",
      "schedule": "0 3 1,15 * *"
    }
  ],
  "functions": {
    "app/api/download-catalog/[type]/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/download-catalogs/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/test-browser-download/route.ts": {
      "maxDuration": 60
    }
  }
}
