// LOCAL DEVELOPMENT DATABASE - SQLite
// For testing sets feature before deploying to production

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-local"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model ApiCallTracker {
  date         String   @id
  call_count   Int      @default(0)
  last_call_at DateTime @default(now())

  @@index([date])
}

model CollectionItem {
  id                      String    @id @default(cuid())
  minifigure_no           String
  minifigure_name         String
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Listing                 Listing[]

  @@unique([userId, minifigure_no, condition])
  @@index([minifigure_no])
  @@index([userId])
  @@index([userId, condition])
}

model Listing {
  id               String         @id @default(cuid())
  userId           String
  collectionItemId String
  title            String
  description      String @db.Text
  platform         String
  condition_detail String @db.Text
  accessories      String? @db.Text
  known_flaws      String? @db.Text
  quantity_to_list Int            @default(1)
  list_price       Float?
  status           String         @default("draft")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  sold_at          DateTime?
  CollectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collectionItemId])
  @@index([status])
  @@index([userId])
  @@index([created_at])
}

model MinifigCache {
  minifigure_no    String   @id
  name             String
  category_id      Int
  image_url        String
  cached_at        DateTime @default(now())
  expires_at       DateTime
  keywords         Json?
  last_searched_at DateTime @default(now())

  @@index([expires_at])
  @@index([name])
}

model MinifigCatalog {
  minifigure_no String   @id
  name          String
  category_id   Int
  category_name String
  year_released String?
  weight_grams  Float?
  search_name   String
  created_at    DateTime @default(now())
  updated_at    DateTime  @updatedAt

  @@index([category_name])
  @@index([search_name])
  @@index([year_released])
}

model PersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  minifigure_no           String
  minifigure_name         String
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  notes                   String?
  acquisition_date        DateTime?
  acquisition_notes       String?
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no, condition])
  @@index([userId])
  @@index([userId, condition])
}

model PriceCache {
  id              String   @id @default(cuid())
  minifigure_no   String
  condition       String
  country_code    String   @default("US")
  region          String   @default("north_america")
  currency_code   String   @default("USD")
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  cached_at       DateTime @default(now())
  expires_at      DateTime @default(now())

  @@unique([minifigure_no, condition, country_code, region])
  @@index([expires_at])
  @@index([minifigure_no])
}

model PriceHistory {
  id              String   @id @default(cuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  recorded_at     DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model ScanHistory {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String?
  detectedItemNo String?
  detectedName   String?
  confidence     Float?
  topMatches     Json?
  scannedAt      DateTime @default(now())

  @@index([scannedAt])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SetCollectionItem {
  id                      String    @id @default(cuid())
  set_no                  String
  set_name                String
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  pricing_currency_code   String?   @default("USD")
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, set_no, condition])
  @@index([set_no])
  @@index([userId])
  @@index([userId, condition])
}

model SetPersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  set_no                  String
  set_name                String
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  pricing_currency_code   String?   @default("USD")
  notes                   String?   @db.Text
  acquisition_date        DateTime?
  acquisition_notes       String?   @db.Text
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, set_no, condition])
  @@index([userId])
  @@index([userId, condition])
}

model SetPriceCache {
  id              String   @id @default(cuid())
  set_no          String
  condition       String
  country_code    String   @default("US")
  region          String   @default("north_america")
  currency_code   String   @default("USD")
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  cached_at       DateTime @default(now())
  expires_at      DateTime @default(now())

  @@unique([set_no, condition, country_code, region])
  @@index([expires_at])
  @@index([set_no])
}

model SetPriceHistory {
  id              String   @id @default(cuid())
  set_no          String
  condition       String
  country_code    String   @default("US")
  region          String   @default("north_america")
  currency_code   String   @default("USD")
  avg_price       Float
  lowest_price    Float
  highest_price   Float
  recorded_at     DateTime @default(now())

  @@index([set_no, condition])
  @@index([recorded_at])
}

model User {
  id                        String                      @id @default(cuid())
  name                      String?
  email                     String                      @unique
  password                  String?
  emailVerified             DateTime?
  image                     String?
  preferredCurrency         String?                     @default("USD")
  preferredCountryCode      String?                     @default("US")
  preferredRegion           String?                     @default("north_america")
  currencySymbol            String?                     @default("$")
  locale                    String?                     @default("en-US")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  scanCredits               Int                         @default(0)
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  subscriptionEndsAt        DateTime?
  subscriptionPlan          String?
  subscriptionStatus        String?
  Account                   Account[]
  CollectionItem            CollectionItem[]
  Listing                   Listing[]
  PersonalCollectionItem    PersonalCollectionItem[]
  SetCollectionItem         SetCollectionItem[]
  SetPersonalCollectionItem SetPersonalCollectionItem[]
  Session                   Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AffiliateClick {
  id           String   @id @default(cuid())
  platform     String   // "amazon" | "bricklink" | "rakuten"
  productType  String   // "set" | "minifig"
  productId    String   // set number or minifig number
  productName  String?
  clickedAt    DateTime @default(now())
  userId       String?  // optional - if logged in

  @@index([platform])
  @@index([clickedAt])
  @@index([productId])
}
