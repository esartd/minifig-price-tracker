// NEON DATABASE - User Data Only
// Contains all user-specific tables (accounts, collections, listings)

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-neon"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model CollectionItem {
  id                      String    @id @default(cuid())
  minifigure_no           String
  minifigure_name         String
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Listing                 Listing[]

  @@unique([userId, minifigure_no, condition])
  @@index([minifigure_no])
  @@index([userId])
}

model Listing {
  id               String         @id @default(cuid())
  userId           String
  collectionItemId String
  title            String
  description      String
  platform         String
  condition_detail String
  accessories      String?
  known_flaws      String?
  quantity_to_list Int            @default(1)
  list_price       Float?
  status           String         @default("draft")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  sold_at          DateTime?
  CollectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collectionItemId])
  @@index([status])
  @@index([userId])
}

model PersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  minifigure_no           String
  minifigure_name         String
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  notes                   String?
  acquisition_date        DateTime?
  acquisition_notes       String?
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no, condition])
  @@index([userId])
}

model PriceHistory {
  id              String   @id @default(cuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  recorded_at     DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model ScanHistory {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String?
  detectedItemNo String?
  detectedName   String?
  confidence     Float?
  topMatches     Json?
  scannedAt      DateTime @default(now())

  @@index([scannedAt])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                     String                   @id @default(cuid())
  name                   String?
  email                  String                   @unique
  password               String?
  emailVerified          DateTime?
  image                  String?
  preferredCurrency      String?                  @default("USD")
  preferredCountryCode   String?                  @default("US")
  preferredRegion        String?                  @default("north_america")
  currencySymbol         String?                  @default("$")
  locale                 String?                  @default("en-US")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  scanCredits            Int                      @default(0)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionEndsAt     DateTime?
  subscriptionPlan       String?
  subscriptionStatus     String?
  Account                Account[]
  CollectionItem         CollectionItem[]
  Listing                Listing[]
  PersonalCollectionItem PersonalCollectionItem[]
  Session                Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
