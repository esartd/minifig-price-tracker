// HOSTINGER MySQL DATABASE - User Data
// Migrated from Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-hostinger"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model CollectionItem {
  id                      String    @id @default(cuid())
  minifigure_no           String
  minifigure_name         String
  quantity                Int
  condition               String
  image_url               String?   @db.Text
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Listing                 Listing[]

  @@unique([userId, minifigure_no, condition])
  @@index([minifigure_no])
  @@index([userId])
  @@index([userId, condition])
}

model Listing {
  id               String         @id @default(cuid())
  userId           String
  collectionItemId String
  title            String
  description      String         @db.Text
  platform         String
  condition_detail String         @db.Text
  accessories      String?        @db.Text
  known_flaws      String?        @db.Text
  quantity_to_list Int            @default(1)
  list_price       Float?
  status           String         @default("draft")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  sold_at          DateTime?
  CollectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collectionItemId])
  @@index([status])
  @@index([userId])
  @@index([created_at])
}

model PersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  minifigure_no           String
  minifigure_name         String
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?   @db.Text
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  notes                   String?   @db.Text
  acquisition_date        DateTime?
  acquisition_notes       String?   @db.Text
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no, condition])
  @@index([userId])
  @@index([userId, condition])
}

model PriceHistory {
  id              String   @id @default(cuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  recorded_at     DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model PriceCache {
  id                 String   @id @default(cuid())
  minifigure_no      String
  condition          String
  six_month_avg      Float?
  current_avg        Float?
  current_lowest     Float?
  suggested_price    Float?
  cached_at          DateTime @default(now())
  last_updated       DateTime @updatedAt

  @@unique([minifigure_no, condition])
  @@index([minifigure_no])
  @@index([last_updated])
}

model ScanHistory {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String?  @db.Text
  detectedItemNo String?
  detectedName   String?
  confidence     Float?
  topMatches     Json?
  scannedAt      DateTime @default(now())

  @@index([scannedAt])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                     String                   @id @default(cuid())
  name                   String?
  email                  String                   @unique
  password               String?
  emailVerified          DateTime?
  image                  String?                  @db.Text
  preferredCurrency      String?                  @default("USD")
  preferredCountryCode   String?                  @default("US")
  preferredRegion        String?                  @default("north_america")
  currencySymbol         String?                  @default("$")
  locale                 String?                  @default("en-US")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  scanCredits            Int                      @default(0)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionEndsAt     DateTime?
  subscriptionPlan       String?
  subscriptionStatus     String?
  Account                Account[]
  CollectionItem         CollectionItem[]
  Listing                Listing[]
  PersonalCollectionItem PersonalCollectionItem[]
  Session                Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model ApiCallTracker {
  date          String   @id
  count         Int      @default(0)
  last_call_at  DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model MinifigCache {
  minifigure_no    String   @id
  name             String
  category_id      Int
  image_url        String?  @db.Text
  keywords         Json?
  expires_at       DateTime
  last_searched_at DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model AffiliateClick {
  id           String   @id @default(cuid())
  platform     String
  productType  String
  productId    String
  productName  String?
  clickedAt    DateTime @default(now())
  userId       String?

  @@index([platform])
  @@index([clickedAt])
  @@index([productId])
}
