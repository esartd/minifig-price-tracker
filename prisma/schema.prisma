// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  collections   CollectionItem[]
  listings      Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model CollectionItem {
  id              String   @id @default(uuid())
  minifigure_no   String
  minifigure_name String
  quantity        Int
  condition       String   // 'new' or 'used'
  image_url       String?

  // Pricing data (stored as separate columns)
  pricing_six_month_avg    Float?
  pricing_current_avg      Float?
  pricing_current_lowest   Float?
  pricing_suggested_price  Float?

  // User ownership
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Listings relationship
  listings     Listing[]

  date_added    DateTime @default(now())
  last_updated  DateTime @updatedAt

  @@unique([userId, minifigure_no, condition]) // Prevent duplicate entries per user
  @@index([minifigure_no])
  @@index([userId])
}

model PriceCache {
  id                       String   @id @default(uuid())
  minifigure_no            String
  condition                String   // 'new' or 'used'

  // Cached pricing data
  six_month_avg            Float
  current_avg              Float
  current_lowest           Float
  suggested_price          Float

  // Cache metadata
  cached_at                DateTime @default(now())
  expires_at               DateTime

  @@unique([minifigure_no, condition]) // One cache entry per minifig+condition
  @@index([minifigure_no])
  @@index([expires_at])
}

model ApiCallTracker {
  date         String   @id  // YYYY-MM-DD format
  call_count   Int      @default(0)
  last_call_at DateTime @default(now())

  @@index([date])
}

model PriceHistory {
  id                String   @id @default(uuid())
  minifigure_no     String
  condition         String   // 'new' or 'used'

  // Historical pricing data
  six_month_avg     Float
  current_avg       Float
  current_lowest    Float
  suggested_price   Float

  // Timestamp for this snapshot
  recorded_at       DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model MinifigCache {
  minifigure_no     String   @id  // Primary key: unique per minifig
  name              String
  category_id       Int
  image_url         String
  keywords          String[] // For fuzzy search (name tokenized into keywords)

  // Cache metadata
  cached_at         DateTime @default(now())
  expires_at        DateTime // Cache for 24 hours max per BrickLink API Terms (other content rule)
  last_searched_at  DateTime @default(now()) // Track when users last searched for this

  @@index([expires_at])
  @@index([name]) // For name-based search
}

model Listing {
  id                   String   @id @default(uuid())

  // Relationships
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionItemId     String
  collectionItem       CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)

  // Generated content
  title                String
  description          String   @db.Text

  // User inputs (used for generation)
  platform             String    // 'facebook', 'ebay', or 'bricklink'
  condition_detail     String    // 'new', 'like_new', 'excellent', 'good', 'fair'
  accessories          String?   // "Helmet, blasters"
  known_flaws          String?   // "Minor print wear on torso"
  quantity_to_list     Int       @default(1)
  list_price           Float?    // User's asking price (defaults to suggested_price)

  // Metadata
  status               String    @default("draft")  // 'draft', 'active', 'sold', 'archived'

  // Timestamps
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  sold_at              DateTime?

  @@index([userId])
  @@index([collectionItemId])
  @@index([status])
}

model MinifigCatalog {
  minifigure_no     String   @id  // Bricklink ID (e.g., "sw1219", "cas004")
  name              String        // Full minifigure name
  category_id       Int
  category_name     String
  year_released     String?       // Can be "?" for unknown
  weight_grams      Float?

  // Search optimization
  search_name       String        // Lowercase name for case-insensitive search

  // Metadata
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([search_name])
  @@index([category_name])
  @@index([year_released])
}
