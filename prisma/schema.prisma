generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model ApiCallTracker {
  date         String   @id
  call_count   Int      @default(0)
  last_call_at DateTime @default(now())

  @@index([date])
}

model CollectionItem {
  id                      String    @id @default(cuid())
  minifigure_no           String
  minifigure_name         String
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Listing                 Listing[]

  @@unique([userId, minifigure_no, condition])
  @@index([minifigure_no])
  @@index([userId])
  @@index([userId, condition])
}

model Listing {
  id               String         @id @default(cuid())
  userId           String
  collectionItemId String
  title            String
  description      String
  platform         String
  condition_detail String
  accessories      String?
  known_flaws      String?
  quantity_to_list Int            @default(1)
  list_price       Float?
  status           String         @default("draft")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  sold_at          DateTime?
  CollectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collectionItemId])
  @@index([status])
  @@index([userId])
  @@index([created_at])
}

model MinifigCache {
  minifigure_no    String   @id
  name             String
  category_id      Int
  image_url        String
  cached_at        DateTime @default(now())
  expires_at       DateTime
  keywords         String[]
  last_searched_at DateTime @default(now())

  @@index([expires_at])
  @@index([name])
}

model MinifigCatalog {
  minifigure_no String   @id
  name          String
  category_id   Int
  category_name String
  year_released String?
  weight_grams  Float?
  search_name   String
  created_at    DateTime @default(now())
  updated_at    DateTime  @updatedAt

  @@index([category_name])
  @@index([search_name])
  @@index([year_released])
}

model PersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  minifigure_no           String
  minifigure_name         String
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  notes                   String?
  acquisition_date        DateTime?
  acquisition_notes       String?
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no, condition])
  @@index([userId])
  @@index([userId, condition])
}

model PriceCache {
  id              String   @id @default(cuid())
  item_no         String
  item_type       String   @default("MINIFIG")
  condition       String
  country_code    String   @default("US")
  region          String   @default("north_america")
  currency_code   String   @default("USD")
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  cached_at       DateTime @default(now())
  expires_at      DateTime

  @@unique([item_no, item_type, condition, country_code, region])
  @@index([expires_at])
  @@index([item_no, item_type])
}

model PriceHistory {
  id              String   @id @default(cuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  recorded_at     DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model ScanHistory {
  id             String   @id @default(cuid())
  userId         String
  imageUrl       String?
  detectedItemNo String?
  detectedName   String?
  confidence     Float?
  topMatches     Json?
  scannedAt      DateTime @default(now())

  @@index([scannedAt])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                        String                       @id @default(cuid())
  name                      String?
  email                     String                       @unique
  password                  String?
  emailVerified             DateTime?
  image                     String?
  preferredCurrency         String?                      @default("USD")
  preferredCountryCode      String?                      @default("US")
  preferredRegion           String?                      @default("north_america")
  currencySymbol            String?                      @default("$")
  locale                    String?                      @default("en-US")
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  scanCredits               Int                          @default(0)
  stripeCustomerId          String?
  stripeSubscriptionId      String?
  subscriptionEndsAt        DateTime?
  subscriptionPlan          String?
  subscriptionStatus        String?
  showOnMinifigLeaderboard  Boolean?                     @default(false)
  showOnSetLeaderboard      Boolean?                     @default(false)
  leaderboardDisplayName    String?
  Account                   Account[]
  CollectionItem            CollectionItem[]
  Listing                   Listing[]
  PersonalCollectionItem    PersonalCollectionItem[]
  Session                   Session[]
  WishlistItem              WishlistItem[]
  SetInventoryItem          SetInventoryItem[]
  SetPersonalCollectionItem SetPersonalCollectionItem[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AffiliateClick {
  id           String   @id @default(cuid())
  platform     String   // "amazon" | "bricklink" | "rakuten"
  productType  String   // "set" | "minifig"
  productId    String   // set number or minifig number
  productName  String?
  clickedAt    DateTime @default(now())
  userId       String?  // optional - if logged in

  @@index([platform])
  @@index([clickedAt])
  @@index([productId])
}

model WishlistItem {
  id              String   @id @default(cuid())
  userId          String
  minifigure_no   String
  minifigure_name String
  image_url       String?
  date_added      DateTime @default(now())
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no])
  @@index([userId])
  @@index([minifigure_no])
}

model SetInventoryItem {
  id                      String   @id @default(cuid())
  box_no                  String
  set_name                String
  category_name           String?
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  pricing_currency_code   String?
  userId                  String
  date_added              DateTime @default(now())
  last_updated            DateTime @updatedAt
  User                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, box_no, condition])
  @@index([box_no])
  @@index([userId])
  @@index([userId, condition])
  @@index([category_name])
}

model SetPersonalCollectionItem {
  id                      String    @id @default(cuid())
  userId                  String
  box_no                  String
  set_name                String
  category_name           String?
  quantity                Int       @default(1)
  condition               String    @default("new")
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  pricing_currency_code   String?
  notes                   String?
  acquisition_date        DateTime?
  acquisition_notes       String?
  display_location        String?
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  User                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, box_no, condition])
  @@index([userId])
  @@index([userId, condition])
  @@index([category_name])
}

model Donation {
  id                String   @id @default(cuid())
  paypalTxnId       String   @unique
  amount            Float
  currency          String   @default("USD")
  donorEmail        String
  donorName         String?
  displayName       String?
  showOnLeaderboard Boolean  @default(false)
  season            String
  status            String   @default("completed")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([season])
  @@index([showOnLeaderboard, season])
}
