generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                    @id @default(cuid())
  name                String?
  email               String                    @unique
  password            String?
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  accounts            Account[]
  collections         CollectionItem[]
  personalCollections PersonalCollectionItem[]
  listings            Listing[]
  sessions            Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model CollectionItem {
  id                      String    @id @default(uuid())
  minifigure_no           String
  minifigure_name         String
  quantity                Int
  condition               String
  image_url               String?
  pricing_six_month_avg   Float?
  pricing_current_avg     Float?
  pricing_current_lowest  Float?
  pricing_suggested_price Float?
  userId                  String
  date_added              DateTime  @default(now())
  last_updated            DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings                Listing[]

  @@unique([userId, minifigure_no, condition])
  @@index([minifigure_no])
  @@index([userId])
}

model PriceCache {
  id              String   @id @default(uuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  cached_at       DateTime @default(now())
  expires_at      DateTime

  @@unique([minifigure_no, condition])
  @@index([minifigure_no])
  @@index([expires_at])
}

model ApiCallTracker {
  date         String   @id
  call_count   Int      @default(0)
  last_call_at DateTime @default(now())

  @@index([date])
}

model PriceHistory {
  id              String   @id @default(uuid())
  minifigure_no   String
  condition       String
  six_month_avg   Float
  current_avg     Float
  current_lowest  Float
  suggested_price Float
  recorded_at     DateTime @default(now())

  @@index([minifigure_no, condition])
  @@index([recorded_at])
}

model MinifigCache {
  minifigure_no    String   @id
  name             String
  category_id      Int
  image_url        String
  cached_at        DateTime @default(now())
  expires_at       DateTime
  keywords         String[]
  last_searched_at DateTime @default(now())

  @@index([expires_at])
  @@index([name])
}

model Listing {
  id               String         @id @default(uuid())
  userId           String
  collectionItemId String
  title            String
  description      String
  platform         String
  condition_detail String
  accessories      String?
  known_flaws      String?
  quantity_to_list Int            @default(1)
  list_price       Float?
  status           String         @default("draft")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  sold_at          DateTime?
  collectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([collectionItemId])
  @@index([status])
}

model MinifigCatalog {
  minifigure_no String   @id
  name          String
  category_id   Int
  category_name String
  year_released String?
  weight_grams  Float?
  search_name   String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([search_name])
  @@index([category_name])
  @@index([year_released])
}

model PersonalCollectionItem {
  id                        String    @id @default(uuid())
  userId                    String
  minifigure_no             String
  minifigure_name           String
  quantity                  Int       @default(1)
  condition                 String    @default("new")
  image_url                 String?
  pricing_six_month_avg     Float?
  pricing_current_avg       Float?
  pricing_current_lowest    Float?
  pricing_suggested_price   Float?
  notes                     String?   @db.Text
  acquisition_date          DateTime?
  acquisition_notes         String?   @db.Text
  display_location          String?
  date_added                DateTime  @default(now())
  last_updated              DateTime  @updatedAt
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minifigure_no, condition])
  @@index([userId])
}
