# Database URL for PostgreSQL (Vercel Postgres or other provider)
# Local development can use SQLite: file:./dev.db
# Production: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/database

# NextAuth Configuration
# Generate a random secret with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional - for Google sign-in)
# Get credentials from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend Email Service (for password reset and transactional emails)
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev

# BrickLink API Credentials
# Get your API keys from: https://www.bricklink.com/v3/api/register_consumer.page
BRICKLINK_CONSUMER_KEY=your_consumer_key_here
BRICKLINK_CONSUMER_SECRET=your_consumer_secret_here
BRICKLINK_TOKEN_VALUE=your_token_value_here
BRICKLINK_TOKEN_SECRET=your_token_secret_here

# Rebrickable API Key (for search functionality)
# Get your API key from: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your_rebrickable_api_key_here

# ============================================
# MARKET WATCH FEATURE
# ============================================

# OpenAI API Key (for GPT-4 Vision AI image analysis)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Credential Encryption Key (for encrypting Facebook credentials)
# Generate a random 32-byte hex key with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# Market Watch Cron Secret (for securing cron endpoint)
# Generate a random secret with: openssl rand -base64 32
MARKET_WATCH_CRON_SECRET=your-random-cron-secret-here

# Feature Flag (enables Facebook scraping functionality)
# Set to "true" to enable, "false" to disable
FACEBOOK_SCRAPER_ENABLED=false

# ============================================
# AFFILIATE LINKS (Monetization)
# ============================================

# Amazon Associates (Primary - highest conversion)
# Get your tag from: https://affiliate-program.amazon.com/
# Your approved tag: ericksu0c-20
AMAZON_AFFILIATE_TAG=ericksu0c-20

# Rakuten Advertising (for LEGO.com links)
# Apply at: https://rakutenadvertising.com/
# Your approved ID: g*DYfXR3HYU
RAKUTEN_AFFILIATE_ID=g*DYfXR3HYU

# BrickLink Affiliate (Optional - for used/collectible market)
# Apply at: https://www.bricklink.com/affiliate.asp
BRICKLINK_AFFILIATE_ID=your_bricklink_id_here

# ============================================
# CATALOG DOWNLOAD AUTOMATION
# ============================================

# Vercel Blob Storage (for storing catalog files)
# Get your token from: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# Browser Automation Settings
# Timeout for BrickLink downloads in milliseconds (default: 60000)
BRICKLINK_DOWNLOAD_TIMEOUT=60000

# Feature flag to enable browser automation for catalog downloads
# Set to "true" to use Puppeteer, "false" to use URL guessing
USE_BROWSER_AUTOMATION=true

# Admin Secret (for testing and manual catalog endpoints)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your-admin-secret-here

# ============================================
# PRICE CACHE PRE-WARMING
# ============================================

# Cron Secret (for securing price refresh endpoint)
# Generate a random secret with: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-here
