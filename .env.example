# Bricklink API Credentials
# Get these from: https://www.bricklink.com/v2/api/register_consumer.page
# (You need to be logged in to your Bricklink account)

BRICKLINK_CONSUMER_KEY=your_consumer_key_here
BRICKLINK_CONSUMER_SECRET=your_consumer_secret_here
BRICKLINK_TOKEN_VALUE=your_token_value_here
BRICKLINK_TOKEN_SECRET=your_token_secret_here

# Rebrickable API Key (free tier available)
# Sign up at: https://rebrickable.com/api/
# Enables name-based minifig search across 20,000+ figures

REBRICKABLE_API_KEY=your_rebrickable_api_key_here
