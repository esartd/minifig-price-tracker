{
  "name": "minifig-price-tracker",
  "version": "1.0.0",
  "description": "Minifig Price Tracker - A tool for Lego minifigure sellers to track inventory and pricing",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validate-schema.js && prisma generate && next build",
    "validate-schema": "node scripts/validate-schema.js",
    "deploy": "bash scripts/deploy.sh",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "restore-collection": "tsx scripts/migrate-existing-data.ts",
    "check-api-usage": "tsx scripts/check-api-usage.ts",
    "fix-names": "tsx scripts/fix-minifig-names.ts",
    "import-catalog": "tsx scripts/import-catalog.ts",
    "check-catalog": "curl https://figtracker.ericksu.com/api/admin/check-catalog-changes",
    "upload-catalog": "curl -X POST https://figtracker.ericksu.com/api/admin/upload-catalog -H 'Authorization: Bearer $ADMIN_SECRET' -H 'Content-Type: text/plain' --data-binary @Minifigures.txt",
    "test-catalog-download": "curl https://figtracker.ericksu.com/api/admin/test-catalog-download -H 'Authorization: Bearer $ADMIN_SECRET'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^5.19.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/postgres": "^0.10.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fuse.js": "^7.1.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.10.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.19.0",
    "tsx": "^4.21.0"
  }
}
